{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "..",
  "testRegex": ".test.ts$",
  "testEnvironment": "node",
  "roots": ["<rootDir>/tests"],
  "globalSetup": "<rootDir>/global-setup.ts",
  "setupFilesAfterEnv": ["<rootDir>/tests/setup/setup-file.ts"],
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "testTimeout": 30000,
  "moduleNameMapper": {
    "^src/(.*)$": "<rootDir>/src/$1"
  }
}
